import mercadopago
import os

def gerar_link_pagamento(nome, email):
    # Usa o token configurado no Render
    token = os.getenv("MP_TOKEN")
    sdk = mercadopago.SDK(token)

    # Criamos as URLs de retorno já com os dados do cliente na "mochila" da URL
    url_sucesso = f"https://pgvnd.onrender.com/compracerta?nome={nome}&email={email}"

    preference_data = {
        "items": [
            {
                "title": "Inscrição São Jorge Para Todos",
                "quantity": 1,
                "currency_id": "BRL",
                "unit_price": 79.90
            }
        ],
        "back_urls": {
            "success": url_sucesso,
            "failure": "https://pgvnd.onrender.com/compraerrada",
            "pending": "https://pgvnd.onrender.com/compraerrada"
        },
        "auto_return": "approved" # Força o retorno imediato após o pagamento
    }
    
    result = sdk.preference().create(preference_data)
    payment = result.get("response")
    
    return payment.get("init_point") if payment else None
